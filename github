name: Refresh leaderboard
on:
  schedule:
    - cron: "0 6 * * *"
  workflow_dispatch:
permissions:
  contents: write
jobs:
  refresh:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "20"
      - name: Update results & standings
        env:
          FOOTBALL_DATA_TOKEN: ${{ secrets.FOOTBALL_DATA_TOKEN }}
        run: node refresh.mjs
      - name: Commit changes
        run: |
          git config user.name "prediction-league-bot"
          git config user.email "bot@users.noreply.github.com"
          git add data.json index.html
          git commit -m "Auto-refresh leaderboard" || echo "No changes"
          git push
